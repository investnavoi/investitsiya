rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ═══════════════════════════════════════
       Helper functions
    ═══════════════════════════════════════ */
    function isAuthed() {
      return request.auth != null;
    }

    /* Domain whitelist disabled — any authenticated user can read.
       To enable, replace return isAuthed() with:
         return isAuthed() && request.auth.token.email != null
           && request.auth.token.email.matches('.*@yourdomain[.]com$'); */
    function hasAllowedEmail() {
      return isAuthed();
    }

    function isAdmin() {
      return isAuthed() && request.auth.token.admin == true;
    }

    /* ═══════════════════════════════════════
       Collections — default DENY, allow explicitly
    ═══════════════════════════════════════ */

    /* Public-read collections (investors list, raw materials, products, forums, etc.)
       Anyone authenticated with whitelisted email can read.
       Only admin can write. */
    match /investors/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }
    match /rawMaterials/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }
    match /products/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }
    match /forums/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }
    match /local/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }
    match /zoom/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }
    match /entrepreneurs/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }

    /* Investor Companies (leads/CRM) — sensitive, whitelisted read only */
    match /investorCompanies/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }

    /* Trade Atlas / import data — heavy, whitelisted read */
    match /tradeData/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }
    match /tradeSnapshots/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }
    match /tradeSnapshotChunks/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }
    match /importSnapshots/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }

    /* Settings — readable by all authed, writable by admin */
    match /settings/{id} {
      allow read: if hasAllowedEmail();
      allow write: if isAdmin();
    }

    /* API Keys — ADMIN ONLY — contains 3rd-party secrets */
    match /apiKeys/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    /* User profile docs (if created) — each user can read/write their own */
    match /users/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow write: if isAuthed() && request.auth.uid == uid;
      /* Admins can read/write all user docs */
      allow read, write: if isAdmin();
    }

    /* Audit logs — admin read, auth users can write their own action */
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    /* Default — deny everything else */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
