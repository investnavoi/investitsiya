rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ═══════════════════════════════════════
       Helper functions
    ═══════════════════════════════════════ */
    function isAuthed() {
      return request.auth != null;
    }

    /* PUBLIC READ — barcha foydalanuvchilarga ochiq (kirish talab qilinmaydi).
       Birinchi martta saytga kirayotganlar ham hamma ma'lumotni ko'rishi uchun. */
    function publicRead() {
      return true;
    }

    /* Domain whitelist disabled — any authenticated user can read.
       To enable, replace return isAuthed() with:
         return isAuthed() && request.auth.token.email != null
           && request.auth.token.email.matches('.*@yourdomain[.]com$'); */
    function hasAllowedEmail() {
      return isAuthed();
    }

    function isAdmin() {
      return isAuthed() && request.auth.token.admin == true;
    }

    /* ═══════════════════════════════════════
       Collections — default DENY, allow explicitly
       READ — public (har kim, kirishsiz ham ko'radi)
       WRITE — faqat admin (funksiyalar cheklangan)
    ═══════════════════════════════════════ */

    /* Public-read collections (investors list, raw materials, products, forums, etc.) */
    match /investors/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }
    match /rawMaterials/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }
    match /products/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }
    match /forums/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }
    match /local/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }
    match /zoom/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }
    match /entrepreneurs/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }

    /* Investor Companies (leads/CRM) — public read */
    match /investorCompanies/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }

    /* Trade Atlas / import data — public read */
    match /tradeData/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }
    match /tradeSnapshots/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }
    match /tradeSnapshotChunks/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }
    match /importSnapshots/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }
    match /taFirmSnapshots/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }

    /* Settings — public read, admin write */
    match /settings/{id} {
      allow read: if publicRead();
      allow write: if isAdmin();
    }

    /* Embassy AI Letters — saqlangan AI xatlar (cross-device sync) */
    match /embassyLetters/{id} {
      allow read: if publicRead();
      allow write: if isAuthed();
    }

    /* AI Invest Analyzer history — public read (jamoaviy tahlil),
       autentifikatsiya qilingan foydalanuvchilar yoza oladi */
    match /investAiHistory/{id} {
      allow read: if publicRead();
      allow write: if isAuthed();
    }

    /* API Keys — ADMIN ONLY — contains 3rd-party secrets */
    match /apiKeys/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    /* User profile docs (if created) — each user can read/write their own */
    match /users/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow write: if isAuthed() && request.auth.uid == uid;
      /* Admins can read/write all user docs */
      allow read, write: if isAdmin();
    }

    /* Audit logs — admin read, auth users can write their own action */
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    /* Default — deny everything else */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
