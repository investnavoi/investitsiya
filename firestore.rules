rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ═══════════════════════════════════════════════════════════════
       ROL MODELI (server tomonda majburlanadi — mijoz kodiga ishonmaymiz)

       Rol Firebase custom claim'da saqlanadi:  { role: '...', admin: bool }
       O'rnatish:  node scripts/set-role-claim.cjs <email> <role>

         superadmin  — HAMMASINI ko'radi va TAHRIRLAYDI (Azizbek, texnik lead)
         admin       — HAMMASINI ko'radi, lekin TAHRIRLAMAYDI (Shahzod, monitoring)
         member      — ko'radi + FAQAT o'z lead ishini bajaradi (email, status, mas'ul)

       Eski akkauntlarda faqat `admin: true` claim bo'lsa — superadmin deb qaraladi
       (migratsiya davri uchun; rollar o'rnatilgach bu fallback olib tashlanadi).
    ═══════════════════════════════════════════════════════════════ */

    function isAuthed() {
      return request.auth != null;
    }

    function role() {
      return isAuthed() ? request.auth.token.get('role', '') : '';
    }

    /* Legacy: eski `admin:true` claim (rol hali o'rnatilmagan) → superadmin */
    function legacyAdmin() {
      return isAuthed() && request.auth.token.get('admin', false) == true && role() == '';
    }

    function isSuperadmin() { return role() == 'superadmin' || legacyAdmin(); }
    function isTeamAdmin()  { return role() == 'admin'; }
    function isMember()     { return role() == 'member'; }

    /* Lead ustida ishlash huquqi: superadmin + member. admin (Shahzod) = faqat ko'radi. */
    function canWorkLeads() { return isSuperadmin() || isMember(); }

    /* Tanilgan jamoa a'zosi */
    function isTeam() { return isSuperadmin() || isTeamAdmin() || isMember(); }

    /* ─── Lead ishi paytida O'ZGARISHI mumkin bo'lgan maydonlar ───
       member faqat shu maydonlarni tegishi mumkin: kompaniya nomi, emaili,
       davlati kabi asosiy ma'lumotni o'zgartira olmaydi va o'chira olmaydi. */
    function onlyLeadWorkFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'assignedTo', 'reservedBy', 'reservedAt',
        'status', 'holat',
        'emailSent', 'emailSentDate', 'emailSentAt', 'sentBy', 'sentByMailbox',
        'emailSchedule', 'aiLetterData',
        'activityLog', 'lastActivityAt', 'updatedBy', 'updatedAt',
        'needsEmail', 'izoh', 'soha'
      ]);
    }

    /* ═══════════════════════════════════════
       GLOBAL MA'LUMOTLAR — hamma o'qiydi, faqat superadmin yozadi
    ═══════════════════════════════════════ */
    match /investors/{id}      { allow read: if isAuthed(); allow write: if isSuperadmin(); }
    match /local/{id}          { allow read: if isAuthed(); allow write: if isSuperadmin(); }
    match /zoom/{id}           { allow read: if isAuthed(); allow write: if isSuperadmin(); }
    match /forums/{id}         { allow read: if isAuthed(); allow write: if isSuperadmin(); }
    match /rawMaterials/{id}   { allow read: if isAuthed(); allow write: if isSuperadmin(); }
    match /products/{id}       { allow read: if isAuthed(); allow write: if isSuperadmin(); }
    match /entrepreneurs/{id}  { allow read: if isAuthed(); allow write: if isSuperadmin(); }
    match /settings/{id}       { allow read: if isAuthed(); allow write: if isSuperadmin(); }

    /* ═══════════════════════════════════════
       LEADLAR (CRM yadrosi)
       - o'qish: har qanday kirgan foydalanuvchi
       - yaratish/o'chirish: faqat superadmin (bulk import ham shu yerda)
       - yangilash: superadmin hammasini; member FAQAT lead-ish maydonlarini
    ═══════════════════════════════════════ */
    match /investorCompanies/{id} {
      allow read:   if isAuthed();
      allow create: if isSuperadmin();
      allow delete: if isSuperadmin();
      allow update: if isSuperadmin()
                    || (canWorkLeads() && onlyLeadWorkFields());
    }

    /* ═══════════════════════════════════════
       SAVDO / IMPORT DATASETLARI — o'qish hammaga, yozish superadmin
    ═══════════════════════════════════════ */
    match /tradeData/{id}           { allow read: if isAuthed(); allow write: if isSuperadmin(); }
    match /tradeSnapshots/{id}      { allow read: if isAuthed(); allow write: if isSuperadmin(); }
    match /tradeSnapshotChunks/{id} { allow read: if isAuthed(); allow write: if isSuperadmin(); }
    match /importSnapshots/{id}     { allow read: if isAuthed(); allow write: if isSuperadmin(); }
    match /taFirmSnapshots/{id}     { allow read: if isAuthed(); allow write: if isSuperadmin(); }

    /* ═══════════════════════════════════════
       JAMOA FAOLIYATI — har a'zo o'z ishini yozadi
       ⚠️ AVVAL YETISHMAYOTGAN EDI → default deny → har yuklashda xato berardi
    ═══════════════════════════════════════ */
    match /crmActivities/{id} {
      allow read:   if isAuthed();
      allow create: if canWorkLeads();
      allow update: if canWorkLeads();
      allow delete: if isSuperadmin();
    }

    /* AI tahlil tarixi va elchixona xatlari — jamoaviy */
    match /investAiHistory/{id} { allow read: if isAuthed(); allow write: if isTeam(); }
    match /embassyLetters/{id}  { allow read: if isAuthed(); allow write: if isTeam(); }

    /* Ijro Intizomi vidjeti va boshqa app meta
       ⚠️ AVVAL YETISHMAYOTGAN EDI → default deny */
    match /appMeta/{id} {
      allow read:  if isAuthed();
      allow write: if isSuperadmin();
    }

    /* ═══════════════════════════════════════
       API KALITLAR
       ⚠️ HOZIRCHA: har qanday jamoa a'zosi o'qiy oladi — chunki AI xat/chatbot
       brauzerdan to'g'ridan-to'g'ri OpenAI/Gemini'ga murojaat qiladi va kalit kerak.
       TO'G'RI YECHIM (rejada): AI chaqiruvlarini ham Vercel proxy orqali o'tkazish,
       shunda kalit brauzerga umuman tushmaydi va bu qoida superadmin'ga cheklanadi.
    ═══════════════════════════════════════ */
    match /apiKeys/{id} {
      allow read:  if isTeam();
      allow write: if isSuperadmin();
    }

    /* ═══════════════════════════════════════
       FOYDALANUVCHI PROFILI — har kim faqat o'zinikini
    ═══════════════════════════════════════ */
    match /users/{uid} {
      allow read, write: if isAuthed() && request.auth.uid == uid;
      allow read, write: if isSuperadmin();
    }

    /* Audit loglari — superadmin o'qiydi, a'zo faqat o'z yozuvini yaratadi */
    match /auditLogs/{id} {
      allow read:   if isSuperadmin();
      allow create: if isAuthed() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    /* ═══════════════════════════════════════
       Qolgan hammasi — RAD ETILADI (fail-closed)
    ═══════════════════════════════════════ */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
